{
    "version": 8,
    "configurePresets": [
        {
            "name": "Clang 17.0.0 arm64-apple-darwin25.1.0",
            "displayName": "Clang 17.0.0 arm64-apple-darwin25.1.0",
            "description": "Using compilers: C = /usr/bin/clang, CXX = /usr/bin/clang++",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/install/${presetName}",
                "CMAKE_C_COMPILER": "/usr/bin/clang",
                "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-x64-debug",
            "displayName": "Windows x64 Debug",
            "description": "Windows x64 Debug",
            "binaryDir": "${sourceDir}/build/windows-x64-debug",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/install/windows-x64-debug",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}
